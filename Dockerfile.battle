# Runtime-only battle runner image.
# Expects pre-built Robocode installation at ./robocode-home/ (created by the workflow).
FROM eclipse-temurin:21-jre-alpine

RUN apk add --no-cache nodejs

# Copy pre-built Robocode installation
COPY robocode-home/ /opt/robocode/

WORKDIR /opt/robocode

# Copy battle runner script
COPY rumble/scripts/run-battle.mjs /opt/rumble/run-battle.mjs

ENV ROBOCODE_DIR=/opt/robocode
ENV NOSECURITY=true

ENTRYPOINT ["node", "/opt/rumble/run-battle.mjs"]
